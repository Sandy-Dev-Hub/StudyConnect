# Flask
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret-key

# Database (PostgreSQL)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/studyconnect
DATABASE_URL=

# Redis (leave empty to use SimpleCache fallback)
REDIS_URL=redis://localhost:6379/0

# Mail (set MAIL_SUPPRESS_SEND=1 to print emails to console)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=StudyConnect <noreply@studyconnect.com>
MAIL_SUPPRESS_SEND=1

# Upload
MAX_CONTENT_LENGTH=5242880
UPLOAD_FOLDER=app/static/uploads
